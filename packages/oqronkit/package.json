{
  "name": "oqronkit",
  "version": "0.0.1-alpha.2",
  "description": "Crash-safe, non-blocking, modular job processing framework for Node.js",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/rohittiwari-dev/oqronkit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./cron": {
      "types": "./dist/cron.d.ts",
      "import": "./dist/cron.mjs",
      "require": "./dist/cron.js"
    },
    "./scheduler": {
      "types": "./dist/scheduler.d.ts",
      "import": "./dist/scheduler.mjs",
      "require": "./dist/scheduler.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "cron-parser": "^4.9.0",
    "eventemitter3": "^5.0.1",
    "find-up": "^7.0.0",
    "rrule": "^2.8.1",
    "voltlog-io": "^1.0.8",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/ioredis": "^5.0.0",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "ioredis": "^5.10.1",
    "pg": "^8.14.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
