{
  "name": "choronoforge",
  "version": "0.0.1",
  "private": false,
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "commit": "cz",
    "changeset": "changeset",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "prepublishOnly": "bun run build",
    "prepare": "bun -e \"if (!process.env.CI) process.exit(1)\" || husky",
    "commitlint": "commitlint --edit",
    "version": "changeset version",
    "release": "bun run build && changeset publish"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "author": "Rohit Tiwari <rohit@rohittiwari.me>",
  "homepage": "https://choronoforge.rohittiwari.me",
  "bugs": {
    "url": "https://github.com/rohittiwari-dev/choronoforge/issues"
  },
  "keywords": [],
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "turbo": "^2.8.19"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "^bun@1.3.9"
}
